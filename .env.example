# PostgreSQL
POSTGRES_USER=printstore
POSTGRES_PASSWORD=changeme
POSTGRES_DB_MEDUSA=medusa
POSTGRES_DB_DIRECTUS=directus
DATABASE_URL=postgresql://printstore:changeme@postgres:5432/medusa
DIRECTUS_DB_URL=postgresql://printstore:changeme@postgres:5432/directus

# Medusa
MEDUSA_JWT_SECRET=supersecretjwt
MEDUSA_COOKIE_SECRET=supersecretcookie
MEDUSA_ADMIN_CORS=http://localhost:9000
MEDUSA_STORE_CORS=http://localhost:3000
MEDUSA_AUTH_CORS=http://localhost:3000,http://localhost:9000

# Stripe
STRIPE_API_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Scaleway Object Storage (S3-compatible)
S3_ENDPOINT=https://s3.nl-ams.scw.cloud
S3_BUCKET=printstore-assets
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=nl-ams

# Scaleway SMTP
SMTP_HOST=smtp.tem.scw.cloud
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourdomain.com

# Directus
DIRECTUS_SECRET=changeme-directus-secret
DIRECTUS_ADMIN_EMAIL=admin@yourdomain.com
DIRECTUS_ADMIN_PASSWORD=changeme

# Nuxt public config
NUXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NUXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NUXT_PUBLIC_DEFAULT_LOCALE=da
